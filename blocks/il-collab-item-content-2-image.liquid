{% comment %}

{% endcomment %}

{% liquid
	assign image = block.settings.image
%}

<div class="il-collab-person__image-container image-container">
	<img class="il-collab-person__image image"
			 src="{{ image | img_url: "master" }}"
			 alt="{{ image.alt }}">
</div>

{% schema %}
{
  "name": "IL Content 2 Image",
	"class": "il-collab-image col-6 mb-col-6",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Photo"
    }
  ],
  "presets": [
    {
      "name": "IL Content 2 Image"
    }
  ]
}
{% endschema %}
