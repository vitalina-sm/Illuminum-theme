{% liquid
    assign heading = block.settings.heading
    assign description = block.settings.description
    assign button_text = block.settings.button_text
    assign button_link = block.settings.button_link
    assign heading_font_style = block.settings.heading_font_style | replace: '_', '-'
    assign description_font_style = block.settings.description_font_style | replace: '_', '-'
    assign show_button = false
    assign alignment = block.settings.alignment
    assign block_class = 'il-text--' | append: block.id

    if button_text != blank and button_link != blank
      assign show_button = true
    endif
 %}

<style>
    .{{ block_class }} {
        .il-text__heading,
        .il-text__heading * {
            text-align: {{ alignment }};
            padding: 0;
            margin: 0;
        }
    }
</style>

<div class="il-text {{ block_class }}">
  <div class="il-text__heading {% if heading_font_style != 'unset' %}{{ heading_font_style }}{% endif %}"
    style="margin: 0; padding: 0; width: 100%;">
    {{ heading }}
  </div>
</div>

{% render 'il-x-margins', parent_class: block_class, settings: block.settings %}

{% schema %}
{
  "name": "IL Text",
  "tag": null,
  "settings": [
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Illuminum wrapping service</p>"
    },
    {
      "type": "select",
      "id": "heading_font_style",
      "label": "Font style",
      "options": [
        {
          "value": "unset",
          "label": "Unset"
        },
        {
          "value": "heading_1",
          "label": "Heading 1"
        },
        {
          "value": "heading_2",
          "label": "Heading 2"
        },
        {
          "value": "heading_3",
          "label": "Heading 3"
        },
        {
          "value": "heading_5",
          "label": "Heading 5"
        },
        {
          "value": "regular_text",
          "label": "Regular text"
        },
        {
          "value": "caption_1",
          "label": "Caption 1"
        },
        {
          "value": "caption_2",
          "label": "Caption 2"
        },
        {
          "value": "caption_3",
          "label": "Caption 3"
        },
        {
          "value": "link_item",
          "label": "Link item"
        }
      ],
        "default": "heading_3"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Margin"
    },
    {
      "type": "checkbox",
      "id": "enable_margin_desktop",
      "label": "Enable on desktop",
      "default": false
    },
    {
      "type": "number",
      "id": "margin_top_desktop",
      "info": "px",
      "label": "Top",
      "default": 0,
      "visible_if": "{{ block.settings.enable_margin_desktop }}"
    },
    {
      "type": "number",
      "id": "margin_bottom_desktop",
      "info": "px",
      "label": "Bottom",
      "default": 0,
      "visible_if": "{{ block.settings.enable_margin_desktop }}"
    },
    {
      "type": "checkbox",
      "id": "enable_margin_mobile",
      "label": "Enable on mobile",
      "default": false
    },
    {
      "type": "number",
      "id": "margin_top_mobile",
      "info": "px",
      "label": "Top",
      "default": 0,
      "visible_if": "{{ block.settings.enable_margin_mobile }}"
    },
    {
      "type": "number",
      "id": "margin_bottom_mobile",
      "info": "px",
      "label": "Bottom",
      "default": 0,
      "visible_if": "{{ block.settings.enable_margin_mobile }}"
    }
  ],
  "presets": [
    {
      "name": "IL Text"
    }
  ]
}
{% endschema %}
