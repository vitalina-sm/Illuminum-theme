{% liquid
    assign heading = block.settings.heading
    assign description = block.settings.description
    assign button_text = block.settings.button_text
    assign button_link = block.settings.button_link
    assign heading_font_style = block.settings.heading_font_style | replace: '_', '-'
    assign description_font_style = block.settings.description_font_style | replace: '_', '-'
    assign show_button = false

    if button_text != blank and button_link != blank
      assign show_button = true
    endif
 %}

<div class="il-text-with-link">
  <p class="il-text-with-link__heading {% if heading_font_style != 'unset' %}{{ heading_font_style }}{% endif %}">
    {{ heading }}
  </p>
  <p class="il-text-with-link__description {% if description_font_style != 'unset' %}{{ description_font_style }}{% endif %}">
    {{ description }}
  </p>
  {% if show_button %}
    <a href="{{ button_link }}" class="il-text-with-link__button link-item-hovered">{{ button_text }}</a>
  {% endif %}
</div>

{% schema %}
{
  "name": "IL Text with link",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Illuminum wrapping service"
    },
    {
      "type": "select",
      "id": "heading_font_style",
      "label": "Font style",
      "options": [
        {
          "value": "unset",
          "label": "Unset"
        },
        {
          "value": "heading_1",
          "label": "Heading 1"
        },
        {
          "value": "heading_2",
          "label": "Heading 2"
        },
        {
          "value": "heading_3",
          "label": "Heading 3"
        },
        {
          "value": "heading_5",
          "label": "Heading 5"
        },
        {
          "value": "regular_text",
          "label": "Regular text"
        },
        {
          "value": "caption_1",
          "label": "Caption 1"
        },
        {
          "value": "caption_2",
          "label": "Caption 2"
        },
        {
          "value": "caption_3",
          "label": "Caption 3"
        }
      ],
        "default": "heading_3"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "For every order placed on Illuminum you can select a gift box"
    },
    {
      "type": "select",
      "id": "description_font_style",
      "label": "Font style",
      "options": [
        {
          "value": "unset",
          "label": "Unset"
        },
        {
          "value": "heading_1",
          "label": "Heading 1"
        },
        {
          "value": "heading_2",
          "label": "Heading 2"
        },
        {
          "value": "heading_3",
          "label": "Heading 3"
        },
        {
          "value": "heading_5",
          "label": "Heading 5"
        },
        {
          "value": "regular_text",
          "label": "Regular text"
        },
        {
          "value": "caption_1",
          "label": "Caption 1"
        },
        {
          "value": "caption_2",
          "label": "Caption 2"
        },
        {
          "value": "caption_3",
          "label": "Caption 3"
        }
      ],
        "default": "regular_text"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "DISCOVER GIFTING OPTIONS"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "visible_if": "{{ block.settings.button_text != blank }}"
    }
  ],
  "presets": [
    {
      "name": "IL Text with link"
    }
  ]
}
{% endschema %}
