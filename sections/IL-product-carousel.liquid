<script src="{{ 'il-product-carousel.js' | asset_url }}" type="module" defer></script>
{% liquid
  assign section_class = 'il-collection--' | append: section.id
  assign title = section.settings.title | newline_to_br
  assign subtitle = section.settings.subtitle | newline_to_br
  assign image = section.settings.image
  assign collection_title = section.settings.collection_title | newline_to_br
  assign button_url = section.settings.button_link
  assign button_text = section.settings.button_text
  assign product_list = section.settings.product_list
%}

<div class="il-collection {{ section_class }}">
	<div class="il-collection__text-container">
		<h2 class="il-collection__title heading-2">{{ title }}</h2>
		<p class="il-collection__subtitle text-light">{{ subtitle }}</p>
	</div>
	<div class="il-collection__content">
		<div class="il-collection__left desktop-only--lg">
			<div class="il-collection__image-container image-container">
			<img class="il-collection__image image"
					 src="{{ image | img_url: 'master' }}"
					 alt="{{ image.alt }}">
		</div>
		</div>
		<div class="il-collection__right">
			<div class="il-collection__info-box desktop-only--lg">
				<div class="il-collection__name heading-3">{{ collection_title }}</div>
				<a href="{{ button_url }}"
					 target="_blank"
					 class="il-collection__link link-item link-item-hovered">
					 {{ button_text }}
				</a>
			</div>
			<il-product-carousel class="il-product-carousel"
													 id="ProductCarousel--{{ section.id }}"
													 data-section-id="{{ section.id }}">
				<div class="il-product-carousel__wrapper swiper-wrapper">
					{% for product in product_list %}
						<div class="il-product-carousel__item swiper-slide product-card">
							<div class="product-card__image-container image-container">
								<img class="product-card__image image"
										 src="{{ product.images.first | img_url: 'master' }}"
										 alt="{{ product.images.first.alt | default: product.title }}">
							</div>
							<div class="product-card__info-container">
								<div class="product-card__title">{{ product.title }}</div>
								<div class="product-card__price">{{ product.price | money_without_trailing_zeros }}</div>
							</div>
							<a class="product-card__url" href="{{ product.url }}"></a>
						</div>
					{% endfor %}
				</div>
			</il-product-carousel>
		</div>
	</div>
</div>

{% render 'il-x-margins', parent_class: section_class, settings: section.settings %}

{% schema %}
{
  "name": "IL Product Carousel",
  "tag": "section",
  "settings": [
  	{
      "type": "header",
      "content": "General content"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Title",
      "default": "Dive into the World of Illuminum"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Title",
      "default": "Unveil the artful fusion of nature and creativity in every scent."
    },
    {
      "type": "header",
      "content": "Collection content"
    },
    {
			"type": "image_picker",
			"id": "image",
			"label": "Image"
		},
		{
      "type": "textarea",
      "id": "collection_title",
      "label": "Collection Title",
      "default": "Core Range"
    },
    {
			"type": "url",
			"id": "button_link",
			"label": "Button link"
		},
		{
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "VIEW THE CATALOG"
    },
		{
			"type": "product_list",
			"id": "product_list",
			"label": "Products"
		},
		{
      "type": "header",
      "content": "Margin"
    },
    {
      "type": "checkbox",
      "id": "enable_margin_desktop",
      "label": "Enable on desktop",
      "default": false
    },
    {
      "type": "number",
      "id": "margin_top_desktop",
      "info": "px",
      "label": "Top",
      "default": 0,
      "visible_if": "{{ section.settings.enable_margin_desktop }}"
    },
    {
      "type": "number",
      "id": "margin_bottom_desktop",
      "info": "px",
      "label": "Bottom",
      "default": 0,
      "visible_if": "{{ section.settings.enable_margin_desktop }}"
    },
    {
      "type": "checkbox",
      "id": "enable_margin_mobile",
      "label": "Enable on mobile",
      "default": false
    },
    {
      "type": "number",
      "id": "margin_top_mobile",
      "info": "px",
      "label": "Top",
      "default": 0,
      "visible_if": "{{ section.settings.enable_margin_mobile }}"
    },
    {
      "type": "number",
      "id": "margin_bottom_mobile",
      "info": "px",
      "label": "Bottom",
      "default": 0,
      "visible_if": "{{ section.settings.enable_margin_mobile }}"
    }
  ],
  "presets": [
    {
      "name": "IL Product Carousel"
    }
  ]
}
{% endschema %}