{% comment %}<script defer>
  document.addEventListener('DOMContentLoaded', () => {
    const sliderEl = document.querySelector('.il-slider__images .swiper-container');
    const sliderSection = document.querySelector('.il-slider');
    let slider;
    if (!sliderEl || !sliderSection) {
      console.warn('Slider container or section not found');
      return;
    }

    // Отслеживание направления скролла
    let lastScrollY = window.scrollY;
    let isScrollingUp = false;

    const updateScrollDirection = () => {
      const currentScrollY = window.scrollY;
      isScrollingUp = currentScrollY < lastScrollY;
      lastScrollY = currentScrollY;

      slider.updateSlidePrevState();
    };

    window.addEventListener('scroll', updateScrollDirection, { passive: true });

    // Троттлинг для обработки событий
    let lastActionTime = 0;
    const throttleAction = (callback) => {
      const now = Date.now();
      if (now - lastActionTime >= 300) { // Задержка 300 мс
        lastActionTime = now;
        callback();
      }
    };

    // Блокировка/разблокировка скролла страницы
    const togglePageScroll = (lock) => {
      document.body.classList.toggle('no-scroll', lock);
    };

    // Инициализация: блокируем скролл страницы
    togglePageScroll(true);

    slider = new Swiper(sliderEl, {
      direction: 'vertical',
      slidesPerView: 1,
      spaceBetween: 0,
      mousewheel: {
        forceToAxis: true,
        sensitivity: 0.5,
        thresholdDelta: 20,
      },
      pagination: {
        el: '.swiper-pagination',
        clickable: true,
        bulletClass: 'swiper-pagination-bullet',
        bulletActiveClass: 'swiper-pagination-bullet-active',
      },
      grabCursor: true,
      allowSlidePrev: true,
      allowTouchMove: true,
      modules: [Swiper.Mousewheel, Swiper.Pagination],
      on: {
        slideChange: function () {
          const isLastSlide = this.activeIndex === this.slides.length - 1;
          console.log('this.activeIndex: ', this.activeIndex)
          console.log('this.slides.length - 1: ', this.slides.length - 1)
          console.log('isLastSlide: ', isLastSlide)
          throttleAction(() => {
            if (isLastSlide) {
              console.log('111111')
              this.params.mousewheel.enabled = false;
              this.mousewheel.disable();
              this.el.style.overscrollBehaviorY = 'auto';
              togglePageScroll(false); // Разблокируем скролл страницы
            } else {
              console.log('222222')
              this.params.mousewheel.enabled = true;
              this.mousewheel.enable();
              this.el.style.overscrollBehaviorY = 'contain';
              togglePageScroll(true); // Блокируем скролл страницы
            }
          });
          this.updateSlidePrevState();
        },
        touchMove: function (event) {
          if (this.activeIndex === this.slides.length - 1 && !isScrollingUp) {
            throttleAction(() => {
              this.allowTouchMove = false;
              setTimeout(() => {
                this.allowTouchMove = true;
              }, 300);
            });
          }
        },
      },
    });

    slider.updateSlidePrevState = function () {
      console.log('updateSlidePrevState');
      const observer = new IntersectionObserver(
              ([entry]) => {
                console.log('observer')
                const isTopAtViewport = sliderSection.getBoundingClientRect().top === 0;
                const isLastSlide = this.activeIndex === this.slides.length - 1;

                throttleAction(() => {
                  if (!isTopAtViewport) {
                    // Слайдер не вверху: скролл страницы
                    this.params.mousewheel.enabled = false;
                    this.mousewheel.disable();
                    this.el.style.overscrollBehaviorY = 'auto';
                    this.allowSlidePrev = false;
                    this.allowTouchMove = true;
                    togglePageScroll(false);
                  } else {
                    console.log('isLastSlide: ', isLastSlide);
                    // Слайдер вверху
                    if (isLastSlide) {
                      console.log('isLastSlide if true', isLastSlide);
                      this.allowSlidePrev = isScrollingUp;
                      if (isScrollingUp) {
                        this.params.mousewheel.enabled = true;
                        this.mousewheel.enable();
                        this.el.style.overscrollBehaviorY = 'contain';
                        togglePageScroll(true);
                      } else {
                        this.params.mousewheel.enabled = false;
                        this.mousewheel.disable();
                      }
                    } else {
                      this.allowSlidePrev = true;
                      this.params.mousewheel.enabled = true;
                      this.mousewheel.enable();
                      this.el.style.overscrollBehaviorY = 'contain';
                      togglePageScroll(true);
                    }
                  }
                });
              },
              {
                root: null,
                threshold: [0], // Отслеживаем любое изменение видимости
              }
      );

      /*observer.observe(sliderSection);

      this.on('slideChange', () => {
        observer.disconnect();
        this.updateSlidePrevState();
      });*/
    };



    document.documentElement.style.setProperty('--scrollbar-width', `${window.innerWidth - document.documentElement.clientWidth}px`);
  });
</script>{% endcomment %}

