{{ 'il-slider.css' | asset_url | stylesheet_tag }}
<script src="{{ 'il-slider-galary.js' | asset_url }}" type="module" defer></script>

<section class="il-slider">
  <div class="il-slider__flex">
    <div class="il-slider__images">
      <div class="swiper-container">
        <div class="swiper-wrapper">
          <div class="swiper-slide">
            <div class="il-slider__image">
              <img src="https://cdn.shopify.com/s/files/1/0921/1445/2824/files/hero-1_d96b2cf0-f135-4f6a-8782-dcb064716c00.jpg?v=1751004702" alt=""/>
