            </div>
            <div class="content">
              <div class="text-wrapper">
                <p class="product-edition">95 PERCENT</p>
                <p class="product-name">Tom Wolfe #234</p>
              </div>
              <div class="product-card">
                <div class="product-card__image">
                  <img src="https://cdn.shopify.com/s/files/1/0921/1445/2824/files/pr-1.jpg?v=1751004865" alt=""/>
                </div>
                <div class="product-card__info">
                  <div class="product-card__product-info">
                    <p class="product-edition">95 PERCENT</p>
                    <p class="product-name">Tom Wolfe #234</p>
                  </div>
                  <div class="product-card__size text"> size 50ml</div>
                  <div class="product-card__price text">50$</div>
                </div>
                <a href="/products/white-gardenia-petals" class="product-card__link"></a>
              </div>
            </div>
          </div>
          <div class="swiper-slide">
            <div class="il-slider__image">
