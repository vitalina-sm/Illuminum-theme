    "il_about_collaboration_rQLtc6": {
      "type": "IL-about-collaboration",
      "blocks": {
        "il_about_collaboration_item_GNpkkA": {
          "type": "il-about-collaboration-item",
          "name": "IL Collaboration Item",
          "settings": {
            "collection_title": "ILLUMINUM 95%"
          },
          "blocks": {
            "il_about_collaboration_item_content_1_9BGQJJ": {
              "type": "il-about-collaboration-item-content-1",
              "name": "IL Collab Content 1",
              "settings": {
                "image": "shopify://shop_images/coll-1.jpg",
                "text": "Illuminum London proudly straddle the worlds of art and fragrance, pushing the boundaries of how we experience scent and altering our pre-conceived perceptions of smell itself. Having collaborated with many artists, designers and architects over the years, it seems only natural they should now be working with chefs and exploring that vital link between food and fragrance. Illuminum invited innovative chefs Jackson Boxer, Yuki Gomi and Tom Wolfe to create three distinctive fragrances that explored the interfaces of this connection, playing with our notions of what we think our nose knows.",
                "content_sequence": "image_text",
                "margin_bottom": 30
              },
              "blocks": {}
            },
            "il_about_collaboration_item_content_1_GAPdtK": {
              "type": "il-about-collaboration-item-content-1",
              "name": "IL Collab Content 1",
              "settings": {
                "image": "shopify://shop_images/coll-2.jpg",
                "text": "Illuminum say: ‘Outside the world of perfume, it is chefs who use their sense of smell on a daily basis to spark or guide their imagination. For Illuminum, this cross-disciplinary collaboration with three thoughtful practitioners, each with a clear view of the role and potential of scent, is a unique opportunity to transcend the borders of experience, expectation and practice in order to fashion the new.’\n\nFormulated in partnership with expert perfumers, the three new scents demonstrate the brand’s ethos of carrying a passion for perfume into fulfilling realms of shared experience, including the worlds of art and culture. For Illuminum, fragrance is an art form in its own right.",
                "content_sequence": "text_image",
                "margin_bottom": 75
              },
              "blocks": {}
            },
            "il_about_collaboration_item_content_2_DyYqqk": {
              "type": "il-about-collaboration-item-content-2",
              "name": "IL Collab Content 2",
              "settings": {
                "margin_bottom": 65
              },
              "blocks": {
                "il_collab_item_content_2_person_gmXaFJ": {
                  "type": "il-collab-item-content-2-person",
                  "name": "IL Content 2 Person",
                  "settings": {
                    "image": "shopify://shop_images/coll-person-1.jpg",
                    "text": "BRUNSWICK HOUSE"
                  },
                  "blocks": {}
                },
                "il_collab_item_content_2_image_rTzrYq": {
                  "type": "il-collab-item-content-2-image",
                  "name": "IL Content 2 Image",
                  "settings": {
                    "image": "shopify://shop_images/coll-product-1.jpg"
                  },
                  "blocks": {}
                },
                "il_collab_item_content_2_text_znPK8b": {
                  "type": "il-collab-item-content-2-text",
                  "name": "IL Content 2 Text",
                  "settings": {
                    "text": "‘Founder of the Brunswick House restaurant and bar in London’s Vauxhall, Jackson Boxer brings his individuality to bear on every facet of the guest experience. Here, within a unique architectural emporium, the antiques themselves are for sale as part of a spirited homage to good taste.’"
                  },
                  "blocks": {}
                }
              },
              "block_order": [
                "il_collab_item_content_2_person_gmXaFJ",
                "il_collab_item_content_2_image_rTzrYq",
                "il_collab_item_content_2_text_znPK8b"
              ]
            },
            "il_about_collaboration_item_content_2_bExMgk": {
              "type": "il-about-collaboration-item-content-2",
              "name": "IL Collab Content 2",
              "settings": {
                "margin_bottom": 65
              },
              "blocks": {
                "il_collab_item_content_2_image_VBAdUz": {
                  "type": "il-collab-item-content-2-image",
                  "name": "IL Content 2 Image",
                  "settings": {
                    "image": "shopify://shop_images/coll-product-1.jpg"
                  },
                  "blocks": {}
                },
                "il_collab_item_content_2_text_jFEeWc": {
                  "type": "il-collab-item-content-2-text",
                  "name": "IL Content 2 Text",
                  "settings": {
                    "text": "“For Yuki Gomi, master of Japanese cooking, teacher, and founder of Yuki’s Kitchen, the ‘95 Percent’ series collaboration is an opportunity to reconnect with a childhood spent in the foothills of Mount Fuji, home to all the subtlety and poetic suggestiveness of Japan’s culinary tradition.” For Yuki’s scent, the notes osmanthus, green tea, tangerine and vetiver are entwined to entice the senses..."
                  },
                  "blocks": {}
                },
                "il_collab_item_content_2_person_zLTNCq": {
                  "type": "il-collab-item-content-2-person",
                  "name": "IL Content 2 Person",
                  "settings": {
                    "image": "shopify://shop_images/coll-person-2.jpg",
                    "text": "YUKI GOMI"
                  },
                  "blocks": {}
                }
              },
              "block_order": [
                "il_collab_item_content_2_image_VBAdUz",
                "il_collab_item_content_2_text_jFEeWc",
                "il_collab_item_content_2_person_zLTNCq"
              ]
            },
            "il_about_collaboration_item_content_2_U8QMr3": {
              "type": "il-about-collaboration-item-content-2",
              "name": "IL Collab Content 2",
              "settings": {
                "margin_bottom": 0
              },
              "blocks": {
                "il_collab_item_content_2_person_eynXJk": {
                  "type": "il-collab-item-content-2-person",
                  "name": "IL Content 2 Person",
                  "settings": {
                    "image": "shopify://shop_images/coll-person-3.jpg",
                    "text": "TOM WOLFE"
                  },
                  "blocks": {}
                },
                "il_collab_item_content_2_text_LQNbNw": {
                  "type": "il-collab-item-content-2-text",
                  "name": "IL Content 2 Text",
                  "settings": {
                    "text": "“London-based Tom Wolfe pioneered the fusion of food with art and product design, carving out a uniquely flamboyant niche in the capital’s culinary landscape. This collaboration with Illuminum is a chance to show off his dazzling talent for drama, story, spectacle and cultural allusion.” Tom Wolfe #234 twists fennel infused with bergamot, geranium and neroli and a base of pine tree with amber to intrigue..."
                  },
                  "blocks": {}
                },
                "il_collab_item_content_2_image_H3TA3V": {
                  "type": "il-collab-item-content-2-image",
                  "name": "IL Content 2 Image",
                  "settings": {
                    "image": "shopify://shop_images/coll-product-2.jpg"
                  },
                  "blocks": {}
                }
              },
              "block_order": [
                "il_collab_item_content_2_person_eynXJk",
                "il_collab_item_content_2_text_LQNbNw",
                "il_collab_item_content_2_image_H3TA3V"
              ]
            }
          },
          "block_order": [
            "il_about_collaboration_item_content_1_9BGQJJ",
            "il_about_collaboration_item_content_1_GAPdtK",
            "il_about_collaboration_item_content_2_DyYqqk",
            "il_about_collaboration_item_content_2_bExMgk",
            "il_about_collaboration_item_content_2_U8QMr3"
          ]
        },
        "il_about_collaboration_item_8y9Czr": {
          "type": "il-about-collaboration-item",
          "name": "IL Collaboration Item",
          "settings": {
            "collection_title": "PERFUME X ARCHITECTURE \nBY ANTONINO CARDILLO"
          },
          "blocks": {
            "il_about_collaboration_item_content_1_GVJjFW": {
              "type": "il-about-collaboration-item-content-1",
              "name": "IL Collab Content 1",
              "settings": {
                "image": "shopify://shop_images/pr-3_ccafb0ea-cb5e-4bc2-a11e-6ec614f83a8a.jpg",
                "text": "Illuminum London proudly straddle the worlds of art and fragrance, pushing the boundaries of how we experience scent and altering our pre-conceived perceptions of smell itself. Having collaborated with many artists, designers and architects over the years, it seems only natural they should now be working with chefs and exploring that vital link between food and fragrance. Illuminum invited innovative chefs Jackson Boxer, Yuki Gomi and Tom Wolfe to create three distinctive fragrances that explored the interfaces of this connection, playing with our notions of what we think our nose knows.",
